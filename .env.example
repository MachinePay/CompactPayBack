# Exemplo de variaveis de ambiente para o backend CompactPay
APP_VERSION=dev
APP_REVISION=

DATABASE_URL=postgresql://user:pass@localhost:5432/compactpay
SECRET_KEY=troque-este-segredo-em-producao

MQTT_BROKER_URL=52.14.249.201
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
START_MQTT_WORKER=true
MQTT_COMMAND_QOS=1

ADMIN_EMAIL=admin@compactpay.com.br
ADMIN_PASSWORD=123456

MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_APP_ID=
MP_CLIENT_SECRET=
MP_OAUTH_REDIRECT_URI=https://SEU_BACKEND.com/api/v1/mercado-pago/oauth/callback
FRONTEND_URL=https://SEU_FRONTEND.com
CORS_ALLOWED_ORIGINS=

MP_DEFAULT_STORE_STREET_NAME=Rua CompactPay
MP_DEFAULT_STORE_STREET_NUMBER=0
MP_DEFAULT_STORE_CITY_NAME=Sao Paulo
MP_DEFAULT_STORE_STATE_NAME=Sao Paulo
MP_DEFAULT_STORE_LATITUDE=-23.55052
MP_DEFAULT_STORE_LONGITUDE=-46.633308
MP_DEFAULT_POS_CATEGORY=7994
MP_POS_CATEGORY_FALLBACKS=7994,7996,7999,5999,5399

# Webhook Mercado Pago:
# https://SEU_BACKEND.com/api/v1/callback-mercado-pago

# Notificacao por e-mail de alertas criticos (maquina offline, pulso ausente).
# Sem SMTP_HOST e ALERT_NOTIFICATION_EMAILS configurados, o worker fica desativado
# sozinho (nao precisa de START_ALERT_NOTIFIER_WORKER=false).
START_ALERT_NOTIFIER_WORKER=true
ALERT_NOTIFIER_INTERVAL_SECONDS=120
ALERT_RENOTIFY_COOLDOWN_MINUTES=60
ALERT_NOTIFY_SEVERIDADES=critico
ALERT_NOTIFICATION_EMAILS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
